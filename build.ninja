ninja_required_version = 1.3

rule listen
    command = tiddlywiki . --listen $in
    description = start server

rule build
    command = tiddlywiki . --build $in
    description = start build

rule clean
    command = git checkout tiddlers/system/*.tid &&$
              git clean -d -f -X
    description = start clean

build listen: listen
    pool = console

build build: build
build clean: clean

default clean

